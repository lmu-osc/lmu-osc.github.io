```{=html}
<%
// Date formatting helper
function formatDate(dateStr) {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  return `${d.getDate().toString().padStart(2, '0')} ${monthNames[d.getMonth()]}, ${d.getFullYear()}`;
}

// Split into upcoming and past
const today = new Date();
today.setHours(0,0,0,0);

const upcomingEvents = [];
const pastEvents = {};

for (const item of items) {
  let endDateStr = item.event && item.event.end_date ? item.event.end_date : null;
  let startDateStr = item.event && item.event.start_date ? item.event.start_date : item.date;
  
  let compareDateStr = endDateStr || startDateStr;
  let compareDate = compareDateStr ? new Date(compareDateStr) : new Date(0);
  
  if (compareDate >= today) {
    upcomingEvents.push(item);
  } else {
    let year = compareDate.getFullYear() || "Unknown Year";
    if (!pastEvents[year]) pastEvents[year] = [];
    pastEvents[year].push(item);
  }
}

const pastYears = Object.keys(pastEvents).sort((a, b) => b - a);

function renderCard(item) {
  const cat = (item.categories && item.categories.length > 0) ? item.categories[0] : "event";
  const desc = (item.event && item.event.description) ? item.event.description : item.event_description;
  
  let dateText = "";
  if (item.event && item.event.start_date) {
    dateText += formatDate(item.event.start_date);
    if (item.event.end_date && item.event.end_date !== item.event.start_date) {
      dateText += " - " + formatDate(item.event.end_date);
    }
  }

  const hosts = item.host || [];
  const organizers = item.organizers || [];
  const presenters = item.presenters || [];
  const instructors = item.instructors || [];
  const helpers = item.helpers || [];
%>
<div class="card mb-4" <%= metadataAttrs(item) %>>
  <div class="card-header d-flex align-items-center justify-content-between gap-2">
    <a class="flex-grow-1 text-truncate fw-semibold fs-5 lh-sm" href="<%- item.path %>"><%- item.title %></a>
    <span class="badge text-bg-light border ms-2 text-nowrap d-none d-md-block"><%- cat %></span>
  </div>

  <div class="row g-0 align-items-center">
    <div class="col-md-2 px-2 d-none d-md-block">
      <a href="<%- item.path %>">
        <img src="/events/images/<%- cat.toLowerCase() %>.svg" class="img-fluid d-block mx-auto rounded-start" alt="<%- cat %>">
      </a>
    </div>

    <div class="col-md-10">
      <div class="card-body">
        <h6 class="card-subtitle mb-2"><%- dateText %></h6>
        <% if (item.event && item.event.time) { %>
        <h6 class="card-subtitle mb-2 text-muted"><%- item.event.time %></h6>
        <% } %>
        
        <p class="card-text card-text-clamp"><%- desc %></p>
        
        <div class="card-text">
          <% if (organizers.length > 0) { %>
          <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
            <span class="small text-body-secondary fw-semibold text-nowrap">Organizers:</span>
            <% organizers.forEach(org => { %>
              <span class="badge rounded-pill text-bg-secondary"><%- org %></span>
            <% }) %>
          </div>
          <% } %>

          <% if (presenters.length > 0) { %>
          <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
            <span class="small text-body-secondary fw-semibold text-nowrap">Presenters:</span>
            <% presenters.forEach(pres => { %>
              <span class="badge rounded-pill text-bg-secondary"><%- pres %></span>
            <% }) %>
          </div>
          <% } %>
          
          <% if (instructors.length > 0) { %>
          <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
            <span class="small text-body-secondary fw-semibold text-nowrap">Instructors:</span>
            <% instructors.forEach(inst => { %>
              <span class="badge rounded-pill text-bg-secondary"><%- inst %></span>
            <% }) %>
          </div>
          <% } %>

          <% if (helpers.length > 0) { %>
          <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
            <span class="small text-body-secondary fw-semibold text-nowrap">Helpers:</span>
            <% helpers.forEach(help => { %>
              <span class="badge rounded-pill text-bg-secondary"><%- help %></span>
            <% }) %>
          </div>
          <% } %>

          <% if (hosts.length > 0) { %>
          <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
            <span class="small text-body-secondary fw-semibold text-nowrap">Hosts:</span>
            <% hosts.forEach(h => { 
                let label = h.abbreviation ? h.abbreviation : h.name;
                let titleAttr = h.abbreviation ? `title="${h.name}"` : "";
            %>
              <span class="badge rounded-pill text-bg-secondary" data-bs-toggle="tooltip" <%- titleAttr %>><%- label %></span>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card-footer">
    <div class="row g-2 align-items-center">
      <div class="col-auto ms-auto">
        <a class="btn btn-primary btn-sm text-nowrap" href="<%- item.path %>">Read More</a>
      </div>
    </div>
  </div>
</div>
<% } %>

<div class="list">
	<h2>Upcoming Events</h2>
	<% upcomingEvents.forEach(item => renderCard(item)) %>

	<h2>Past Events</h2>
	<% pastYears.forEach(year => { %>
		<h3><%- year %></h3>
		<% pastEvents[year].forEach(item => renderCard(item)) %>
	<% }) %>
</div>
```