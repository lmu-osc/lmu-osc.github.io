<%
  const today = new Date();
  today.setHours(0, 0, 0, 0);

  const upcomingItems = [];
  for (const item of items) {
    let keep = false;
    if (item.event) {
      if (item.event.start_date) {
        if (new Date(item.event.start_date) >= today) keep = true;
      }
      if (item.event.end_date) {
        if (new Date(item.event.end_date) >= today) keep = true;
      }
    }
    if (keep) upcomingItems.push(item);
  }

  // Sort upcoming events by start_date ascending
  upcomingItems.sort((a, b) => {
    let aDate = a.event && a.event.start_date ? new Date(a.event.start_date) : new Date('9999-12-31');
    let bDate = b.event && b.event.start_date ? new Date(b.event.start_date) : new Date('9999-12-31');
    return aDate - bDate;
  });

  function formatDate(dStr) {
    if (!dStr) return '';
    const parts = dStr.split('-');
    if (parts.length === 3) {
      const d = new Date(parts[0], parts[1] - 1, parts[2]);
      const day = String(d.getDate()).padStart(2, '0');
      const month = d.toLocaleString('en-US', { month: 'short' });
      const year = d.getFullYear();
      return `${day} ${month}, ${year}`;
    }
    return dStr;
  }
%>
<div class="events-list list">

<% for (const item of upcomingItems) { 
  let category = (item.categories && item.categories.length > 0) ? item.categories[0] : '';
  let cat_img = category ? category.toLowerCase().replace(/ /g, '_').replace(/-/g, '_') : 'default';
  let imgSrc = item.card_image ? item.card_image : `/events/images/${cat_img}.svg`;

  let dateText = '';
  if (item.event && item.event.start_date && item.event.end_date && item.event.start_date !== item.event.end_date) {
      dateText = `${formatDate(item.event.start_date)} - ${formatDate(item.event.end_date)}`;
  } else if (item.event && item.event.start_date) {
      dateText = formatDate(item.event.start_date);
  }

  let description = item.event && item.event.description ? item.event.description : item.event_description;

  function getNonEmptyItems(arr) {
    if (!arr || !Array.isArray(arr)) return [];
    return arr.filter(x => {
      if (typeof x === 'string') return x.trim() !== '';
      if (x && typeof x === 'object') {
        const name = x.name || x.abbreviation || '';
        return typeof name === 'string' && name.trim() !== '';
      }
      return false;
    });
  }

  let validOrganizers = getNonEmptyItems(item.organizers);
  let validPresenters = getNonEmptyItems(item.presenters);
  let validInstructors = getNonEmptyItems(item.instructors);
  let validHelpers = getNonEmptyItems(item.helpers);
  let validHosts = getNonEmptyItems(item.host || item.hosts);
%>

<div class="card mb-4" <%= metadataAttrs(item) %>>
  <div class="card-header d-flex align-items-center justify-content-between gap-2">
    <!-- different titles for different screen sizes -->
    <a class="flex-grow-1 card-title-clamp fw-semibold fs-5 lh-sm d-md-none listing-title" href="<%- item.path %>"><%- item.title %></a>
    <a class="flex-grow-1 text-truncate fw-semibold fs-5 lh-sm d-none d-md-block listing-title" href="<%- item.path %>"><%- item.title %></a>
    <% if (category) { %>
      <span class="badge text-bg-light border ms-2 text-nowrap d-none d-md-block listing-categories"><%- category %></span>
    <% } %>
  </div>

  <!-- start row -->
  <div class="row g-0 align-items-center">
    <div class="col-md-2 px-2 py-3 d-none d-md-block">
      <a href="<%- item.path %>">
        <img src="<%- imgSrc %>" onerror="this.onerror=null; this.src='/events/images/default.svg';" class="img-fluid d-block mx-auto rounded-start" alt="<%- category %>">
      </a>
    </div>

    <div class="col-md-10">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 listing-date" style="display:none;"><%- item.event && item.event.start_date ? formatDate(item.event.start_date) : '' %></h6>
        <h6 class="card-subtitle mb-2"><%- dateText %></h6>
        <% if (item.event) { 
             let infosFull = [];
             let infosMobile = [];
             
             if (item.event.time) {
                let obj = { icon: 'bi-clock', text: item.event.time };
                infosFull.push(obj);
                infosMobile.push(obj);
             }
             if (item.event.location) {
                let locText = item.event.location.name ? item.event.location.name : item.event.location;
                if (typeof locText === 'string') {
                  infosFull.push({ icon: 'bi-geo-alt-fill', text: locText });
                }
             }
             if (item.event.format) {
                let fmtText = item.event.format.type ? item.event.format.type : item.event.format;
                if (typeof fmtText === 'string') {
                  infosFull.push({ icon: 'bi-person-video3', text: fmtText });
                  infosMobile.push({ icon: 'bi-person-video3', text: fmtText });
                }
             }
             if (item.event.language) {
                let langText = item.event.language.primary ? item.event.language.primary : item.event.language;
                if (typeof langText === 'string') {
                  infosFull.push({ icon: 'bi-translate', text: langText });
                  infosMobile.push({ icon: 'bi-translate', text: langText });
                }
             }
        %>
          <% if (infosFull.length > 0) { %>
            <h6 class="card-subtitle mb-2 d-none d-md-block">
              <% for (let i = 0; i < infosFull.length; i++) { %>
                <i class="bi <%= infosFull[i].icon %>"></i> <%- infosFull[i].text %><% if (i < infosFull.length - 1) { %> | <% } %>
              <% } %>
            </h6>
          <% } %>
          <% if (infosMobile.length > 0) { %>
            <h6 class="card-subtitle mb-2 d-block d-md-none">
              <% for (let i = 0; i < infosMobile.length; i++) { %>
                <i class="bi <%= infosMobile[i].icon %>"></i> <%- infosMobile[i].text %><% if (i < infosMobile.length - 1) { %> | <% } %>
              <% } %>
            </h6>
          <% } %>
        <% } %>

        <p class="card-text card-text-clamp listing-description"><%- description %></p>
        <div class="card-text">
          <% if (validOrganizers.length > 0) { %>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
              <span class="small text-body-secondary fw-semibold text-nowrap">Organizers:</span>
              <% for (const org of validOrganizers) { %>
                <span class="badge rounded-pill text-bg-secondary"><%- typeof org === 'string' ? org : (org.name || org.abbreviation) %></span>
              <% } %>
            </div>
          <% } %>
          
          <% if (validPresenters.length > 0) { %>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
              <span class="small text-body-secondary fw-semibold text-nowrap">Presenters:</span>
              <% for (const pres of validPresenters) { %>
                <span class="badge rounded-pill text-bg-secondary"><%- typeof pres === 'string' ? pres : (pres.name || pres.abbreviation) %></span>
              <% } %>
            </div>
          <% } %>

          <% if (validInstructors.length > 0) { %>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
              <span class="small text-body-secondary fw-semibold text-nowrap">Instructors:</span>
              <% for (const inst of validInstructors) { %>
                <span class="badge rounded-pill text-bg-secondary"><%- typeof inst === 'string' ? inst : (inst.name || inst.abbreviation) %></span>
              <% } %>
            </div>
          <% } %>

          <% if (validHelpers.length > 0) { %>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2 d-none d-md-block">
              <span class="small text-body-secondary fw-semibold text-nowrap">Helpers:</span>
              <% for (const helper of validHelpers) { %>
                <span class="badge rounded-pill text-bg-secondary"><%- typeof helper === 'string' ? helper : (helper.name || helper.abbreviation) %></span>
              <% } %>
            </div>
          <% } %>

          <% if (validHosts.length > 0) { %>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
              <span class="small text-body-secondary fw-semibold text-nowrap">Hosts:</span>
              <% for (const host of validHosts) { %>
                <% if (typeof host === 'object' && host.abbreviation && host.name) { %>
                  <span class="badge rounded-pill text-bg-secondary" data-bs-toggle="tooltip" title="<%- host.name %>"><%- host.abbreviation %></span>
                <% } else { %>
                  <span class="badge rounded-pill text-bg-secondary"><%- typeof host === 'string' ? host : (host.abbreviation || host.name) %></span>
                <% } %>
              <% } %>
            </div>
          <% } %>
        </div>

      <!-- end card-body -->
      </div>
    <!-- end col-md-10 -->
    </div>
  <!-- end row -->
  </div>
  
  <div class="card-footer">
    <div class="row g-2 align-items-center">
      <div class="col">
        <% if (item.contact && item.contact.email) { %>
            Questions? Contact <a href="mailto:<%- item.contact.email %>"><%- item.contact.name || item.contact.email %></a>
        <% } %>
      </div>
      <div class="col-auto ms-auto">
        <a class="btn btn-primary btn-sm text-nowrap" href="<%- item.path %>">Read More</a>
      </div>
    </div>
  </div>

</div>
<% } %>
</div>
```