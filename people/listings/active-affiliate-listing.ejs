<%
const activeAffiliateItems = (items || []).filter((item) => {
  const memberships = Array.isArray(item.memberships) ? item.memberships : [];

  return memberships.some((membership) => {
    if (!membership || typeof membership !== 'object') return false;

    return ['affiliate'].includes(membership.type) && membership.status === 'active';
  });
});
%>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3  g-3 py-4 list">

<% for (const item of activeAffiliateItems) { %>
<%
  const memberships = Array.isArray(item.memberships) ? item.memberships : [];
  const activeAffiliateMembership = memberships.find((membership) => {
    if (!membership || typeof membership !== 'object') return false;
    return membership.type === 'affiliate' && membership.status === 'active';
  });
  const affiliateOrganization =
    typeof activeAffiliateMembership?.organization === 'string' &&
    activeAffiliateMembership.organization.trim() !== '' &&
    activeAffiliateMembership.organization !== 'NA'
      ? activeAffiliateMembership.organization
      : '';
%>


<div class="col" <%= metadataAttrs(item) %>>
<div class="card h-100">
<div class="position-absolute top-0 end-0 p-1">
<% if (item.social_media && item.social_media.ORCID) { %>
<a href="<%= item.social_media.ORCID %>" target="_blank">
<i class="fa-brands fa-orcid fa-lg" style="color: #A6CE39;"></i>
</a>
<% } %>
</div>
<div class="card-body d-flex flex-column align-items-center">
<img src="people/<%= item.photo || '/images/default.svg' %>" class="rounded-circle border border-3 mb-4" alt="Profile <%= item.name %>"
width="120" height="120"  >
<h5 class="card-title fw-bold text-center listing-name mb-4"><%= item.name %></h5>
<div class="mt-auto">
<h6 class="card-subtitle text-center fw-semibold lh-base text-muted mb-1"><%= item.academic_title %></h6>
<% if (affiliateOrganization) { %>
<p class="card-text lh-base"><%= affiliateOrganization %></p>
<% } %>
</div>
</div>
<a href="<%= item.path %>" class="stretched-link"></a>
</div>
</div>
<% } %>
</div>

<style>


.card {
  transition: all 0.4s ease;  /* adjust speed here */
}

.card:hover {
  transform: translateY(-5px) scale(1.025);
  box-shadow: 0 8px 32px rgba(43,134,75,0.15);
  border-color: var(--osc-accent);
}


.card img {
  object-fit: cover;
  border-color: var(--osc-accent) !important;
}

</style>









