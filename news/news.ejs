<%
const slides = (Array.isArray(items) && items.length) ? items.slice(0, 3) : [];
%>

<div class="carousel-styled-wrapper">
<div id="newsCarousel" class="carousel slide carousel-fade carousel-dark p-4" data-bs-ride="carousel">
<h3 class="news-carousel-heading">News</h3>
<div class="carousel-inner">
<% slides.forEach((item, index) => { %>
<div class="carousel-item <%= index === 0 ? 'active' : '' %>">
<div class="card border-0 news-card">
<% const imgSrc = item.image || '/assets/img/osc_image_assets/LMU_Open_Science_Center_Logo.jpg'; %>
<% const isDefaultImage = !item.image; %>
<% let imgStyle = "aspect-ratio: 16/12; object-fit: " + (isDefaultImage ? 'contain' : 'cover') + "; object-position: center;"; %>
<% if (isDefaultImage) { imgStyle += " background-color: #fff;"; } %>
<img src="<%= imgSrc %>" class="card-img-top d-block w-100" alt="<%= item.title || '' %>" style="<%= imgStyle %>">
<div class="card-body text-center">
<% if (item.title) { %>
<div class="card-title-custom" style="display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.5em; line-height: 1.25;"><%= item.title %></div>
<% } %>
<p class="card-text" style="display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; min-height: 4.5em; line-height: 1.5em; font-size:0.83rem;"><%= item.description %></p>
<% if (item.path) { %>
<a href="<%= item.path %>" class="btn btn-sm news-read-btn" role="button">Read More!</a>
<% } %>
</div>
</div>
</div>
<% }); %>
<div class="carousel-indicators">
<% slides.forEach((item, index) => { %>
<button type="button" data-bs-target="#newsCarousel" data-bs-slide-to="<%= index %>" class="<%= index === 0 ? 'active' : '' %>" aria-current="<%= index === 0 ? 'true' : 'false' %>" aria-label="Slide <%= index + 1 %>"></button>
<% }); %>
</div>
</div>



<button class="carousel-control-prev news-prev" type="button" data-bs-target="#newsCarousel" data-bs-slide="prev">
<i class="bi bi-chevron-left" aria-hidden="true"></i>
<span class="visually-hidden">Previous</span>
</button>
<button class="carousel-control-next news-next" type="button" data-bs-target="#newsCarousel" data-bs-slide="next">
<i class="bi bi-chevron-right" aria-hidden="true"></i>
<span class="visually-hidden">Next</span>
</button>

</div>

<div class="text-center mt-3 mb-2">
<a href="/news" class="btn btn-outline-success btn-sm px-4" role="button">View All News</a>
</div>

</div>

<style>

/* Card title styling */
      .card-title-custom {
        font-weight: 700;
        font-size: 1rem;
      }

      /* Card body styling */
      .carousel-styled-wrapper .card-body {
        background-color: #f5f5f5;
        border-radius: 0 0 0.25rem 0.25rem;
      }

      /* Override carousel-dark filter for news carousel controls */
      .carousel-dark .carousel-control-prev-icon,
      .carousel-dark .carousel-control-next-icon {
        filter: none;
      }
      
      /* News carousel wrapper styling */
      .carousel-styled-wrapper {
          padding: 1.25rem 1.25rem 1rem;
          border-radius: 10px;
          border: 1px solid var(--green-100, #d4eddf);
          background: var(--white, #fff);
      }

      /* ── Heading ── */
      .news-carousel-heading{
        font-size: 1.05rem;
        font-weight: 400;
        color: var(--ink, #333);
        text-align: center;
        margin: 0 0 0.75rem;
        letter-spacing: 0.01em;
        border-bottom: 1px solid rgb(203, 242, 203);
      }
      /* ── Prev / Next controls ── */
      .news-prev,
      .news-next {
        width: 28px;
        height: 28px;
        top: auto;
        bottom: 16rem;
        background: none;
        border: 1px solid #d4eddf14;
        border-radius: 50%;
        color: var(--green-500, #00883bb5);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
        transition: background 0.2s;
      }
      .news-prev { left: 0.5rem; }
      .news-next { right: 0.5rem; }
      .news-prev:hover,
      .news-next:hover {
        background: var(--green-500, #00883A);
        color: #fff;
        border-color: var(--green-500, #00883A);
      }
      .news-prev i,
      .news-next i {
        font-size: 0.75rem;
        line-height: 1;
      }

      .news-read-btn {
        background: var(--green-main, #00883A);
        color: #fff !important;
        border: none;
        font-size: 0.80rem;
        font-weight: 600;
        padding: 0.35rem 1.1rem;
        border-radius: 5px;
        text-decoration: none !important;
        transition: background 0.2s;
      }

      .news-read-btn:hover { background: var(--green-dark, #006b2d); }

</style>